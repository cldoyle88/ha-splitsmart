{
  "name": "@splitsmart/card",
  "version": "0.1.0-m2",
  "private": true,
  "type": "module",
  "description": "Lovelace custom card for the Splitsmart HA integration.",
  "scripts": {
    "build": "rollup -c",
    "build:prod": "cross-env NODE_ENV=production rollup -c",
