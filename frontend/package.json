    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^20.0.0",
    "@vitest/browser": "^2.0.0",
    "cross-env": "^10.1.0",
    "jsdom": "^25.0.0",
    "rollup": "^4.20.0",
    "tslib": "^2.6.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
